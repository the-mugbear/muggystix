# Database backups produced by scripts/backup-db.sh — operator-local,
# may contain real scan data, never committed.
backups/

# Agent session-scoped working directories — created by the agent at
# its repo cwd when the operator runs `claude-code` / `codex` from the
# project root.  Contain raw scanner output (nmap XML, masscan
# results, eyewitness screenshots), live API key payloads in flight,
# and operator-host environment probes — none of which belong in the
# repo.  Matches `networkmapper-<project>-<workflow>-<id>/` and the
# pre-1.23.0 `networkmapper-<workflow>-<id>/`.
networkmapper-*-*/
networkmapper-recon-*/
networkmapper-execution-*/

