# =============================================================================
# NetworkMapper Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your deployment.
# The deploy script (./scripts/deploy.sh) can auto-detect your IP address
# and generate this file for you.
#
# Docker Compose reads .env automatically from the project root.
#
# Every variable read by the backend (and consumed by docker-compose.yml)
# is documented below.  Most have sensible defaults — only HOST_IP,
# REACT_APP_API_URL, CORS_ORIGINS, the POSTGRES_* trio, and SECRET_KEY
# are required to deploy.
# =============================================================================

# -----------------------------------------------------------------------------
# Host / Network
# -----------------------------------------------------------------------------
# IP address or hostname where NetworkMapper is accessible.
# The deploy script can auto-detect this, or set it manually.
#
# Examples:
#   HOST_IP=127.0.0.1          # Localhost development
#   HOST_IP=192.168.1.100      # Local network
#   HOST_IP=10.0.1.50          # Cloud/VPN network
#   HOST_IP=203.0.113.10       # Public server
HOST_IP=127.0.0.1

# -----------------------------------------------------------------------------
# Frontend API URL
# -----------------------------------------------------------------------------
# URL the frontend uses to reach the backend API (through nginx reverse proxy).
# Must match HOST_IP. Always use HTTPS.
#
# Values: https://<HOST_IP>
REACT_APP_API_URL=https://127.0.0.1

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Comma-separated list of origins allowed to make API requests.
# Must include the frontend URL. Always use HTTPS.
#
# Values: https://<HOST_IP>,https://<HOST_IP>:3000
# Both localhost and 127.0.0.1 are included by default so either URL works.
# The deploy script adds these automatically for any IP.
CORS_ORIGINS=https://127.0.0.1,https://127.0.0.1:3000,https://localhost,https://localhost:3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL credentials. Used by both the db container and backend.
#
#   POSTGRES_DB:       Database name
#   POSTGRES_USER:     Database username
#   POSTGRES_PASSWORD: Database password
#   DATABASE_SSL_MODE: SSL mode for backend-to-database connections
#     disable | allow | prefer | require | verify-ca | verify-full
#     Use "disable" for local dev, "prefer" or "require" for production.
#
# POSTGRES_DB=networkMapper
# POSTGRES_USER=nmapuser
# POSTGRES_PASSWORD=nmappass
DATABASE_SSL_MODE=prefer

# Connection pool — values below are PER uvicorn worker PROCESS.
# The API container runs UVICORN_WORKERS (default 4) separate processes,
# each with its own pool, so the real ceiling on Postgres connections is:
#
#   UVICORN_WORKERS * (DB_POOL_SIZE + DB_MAX_OVERFLOW)  +  worker container
#
# This total MUST stay below the db container's max_connections
# (PG_MAX_CONNECTIONS, default 120).  With the defaults below:
#   4 * (5 + 10) + (5 + 10) = 75   < 120   ✓
# Lower bound still applies — a startup warning fires if
# DB_POOL_SIZE + DB_MAX_OVERFLOW < 2 * UVICORN_WORKERS.
# Note: agent (/api/v1/agent/*) traffic shares this same pool — agents
# are bursty, not sustained, so they need no separate budget, but each
# agent call also triggers one short audit-log write on its own connection.
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT — seconds a request waits for a free pooled connection
# before failing fast (instead of piling up behind the post-response audit
# writer, which briefly holds a 2nd connection per agent call).  Default 30.
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE — proactively retire a pooled connection older than this
# many seconds so a proxy / Postgres idle timeout can't hand back a dead
# socket.  Default 1800 (30 min).  pre-ping already revalidates on checkout.
# DB_POOL_RECYCLE=1800

# DATABASE_URL — full SQLAlchemy connection string.  Normally you should NOT
# set this: docker-compose builds it automatically from the POSTGRES_* values
# above (postgresql://<user>:<pass>@db:5432/<db>).  Override only to point the
# backend at an external/managed Postgres instead of the bundled db container.
# DATABASE_URL=postgresql://nmapuser:nmappass@db:5432/networkMapper

# Boot-time DB connect retries.  Backend waits for the postgres container
# to accept connections; bump if your DB takes longer to come up.
# DB_INIT_MAX_RETRIES=10
# DB_INIT_RETRY_DELAY=3

# PostgreSQL server tuning — passed to the db container as `postgres -c`
# flags (see docker-compose.yml).  Defaults are conservative and safe on
# a ~2-4GB host.  Scale to the deployment host's RAM:
#   shared_buffers       ~= 25% of RAM
#   effective_cache_size ~= 60-75% of RAM
# Example for a 16GB host:
#   PG_SHARED_BUFFERS=4GB
#   PG_EFFECTIVE_CACHE_SIZE=10GB
#   PG_WORK_MEM=24MB
#   PG_MAINTENANCE_WORK_MEM=512MB
# max_connections rarely needs raising — the pool math above already
# fits under 120; only raise it if you also raise UVICORN_WORKERS / pools.
# PG_MAX_CONNECTIONS=120
# PG_SHARED_BUFFERS=256MB
# PG_EFFECTIVE_CACHE_SIZE=768MB
# PG_WORK_MEM=8MB
# PG_MAINTENANCE_WORK_MEM=128MB

# -----------------------------------------------------------------------------
# Security — REQUIRED for production
# -----------------------------------------------------------------------------
# SECRET_KEY is REQUIRED.  Used for session encryption + as the fallback
# for JWT_SECRET_KEY and CREDENTIAL_ENCRYPTION_KEY when those are unset.
# Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Leave empty ONLY for short-lived local development — the backend will
# fall back to a random per-process key and every container restart will
# invalidate every JWT and every stored agent API key.
SECRET_KEY=

# JWT_SECRET_KEY — defaults to SECRET_KEY if unset.  Set independently
# if you want to rotate the JWT key without invalidating stored agent
# credentials (recommended for production).
# JWT_SECRET_KEY=

# CREDENTIAL_ENCRYPTION_KEY — Fernet key for encrypting per-user LLM
# provider API keys and scanner integration secrets at rest.  Falls
# back to SECRET_KEY for backwards compatibility, but the backend logs
# a deprecation warning on every encrypt/decrypt if it's used unset.
# Generate the same way as SECRET_KEY.
# CREDENTIAL_ENCRYPTION_KEY=

# How long human-user access tokens remain valid (in minutes).
# Default: 480 (8 hours).
# ACCESS_TOKEN_EXPIRE_MINUTES=480

# Mandatory two-factor authentication.  Default: true — every user must enroll
# in TOTP 2FA before reaching any data endpoint (they're forced to the 2FA
# setup page after login).  Set to false for opt-in 2FA (e.g. an air-gapped
# single-operator box).
# REQUIRE_2FA=true

# How long agent API keys (recon / plan-generation / execution) remain
# valid before requiring rotation.  Default: 24 hours.
# AGENT_KEY_TTL_HOURS=24

# Hard upper bound on the TTL an operator may request when creating/renewing
# an agent key — requests over the cap are clamped down (with a warning).
# Default: 168 (7 days).  Raise only for engagements that genuinely need a
# longer-lived key; past a week a leaked key's blast radius is large.
# AGENT_KEY_MAX_TTL_HOURS=168

# Hard cap (bytes) on any outbound HTTP response body the backend buffers
# into memory — LLM provider replies, scanner-integration calls, webhook
# acks.  Stops a hostile/misconfigured endpoint from ballooning RAM via a
# huge response.  Default: 10485760 (10 MiB), far above any legitimate body.
# MAX_OUTBOUND_RESPONSE_BYTES=10485760

# Optional contact string surfaced in the /.well-known/networkmapper.json
# identity document agents consult to verify the instance.
# NM_SECURITY_CONTACT=security@example.com

# DNS server allowlist (CIDR ranges) for the per-host DNS-server config
# on scan uploads.  Empty = no allowlist (any DNS server accepted).
# Pass IPv4 or IPv6 CIDRs, comma-separated.
# DNS_SERVER_ALLOWLIST=10.0.0.0/8,192.168.0.0/16

# -----------------------------------------------------------------------------
# Default Admin Account
# -----------------------------------------------------------------------------
# Only used on first boot when no admin user exists.
# If DEFAULT_ADMIN_PASSWORD is unset (or set to the literal "admin"), the
# seeder generates a RANDOM password and writes it once to
# ./uploads/initial-admin-password.txt (0600) — read it there, then change it
# (forced on first login). The generated password is NOT logged. If the uploads
# volume isn't writable, startup fails closed rather than create an
# unrecoverable admin — set DEFAULT_ADMIN_PASSWORD or fix the volume. Custom
# values are NEVER logged.
#
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Uvicorn / Worker tuning (optional)
# -----------------------------------------------------------------------------
# UVICORN_WORKERS controls the API container's worker count.  Default 4.
# Lowering this on small hosts (1-2 vCPU) prevents pool starvation; raising
# helps high-traffic deployments at the cost of memory.
# UVICORN_WORKERS=4

# Ingestion worker poll interval (seconds).  How often the background
# parser checks for queued upload jobs.  Default 5; drop to 1-2 for
# faster pickup on bursty workloads.
# WORKER_POLL_INTERVAL=5

# NOTE: there is no INGESTION_WORKERS setting.  The ingestion worker is a
# single process by design (the queue's SELECT … FOR UPDATE SKIP LOCKED claim
# is serial).  To run more parsers in parallel, scale the container instead:
#   docker compose up -d --scale worker=N

# Max seconds a single ingestion job may run before being marked failed
# by the reaper loop.  Default 1800 (30 minutes) — appropriate for
# large nmap/Nessus parses.
# INGESTION_JOB_TIMEOUT=1800

# How many times the orphan reaper auto-requeues a job whose worker died
# mid-parse (transient OOM/restart) before giving up and failing it.  The
# stored upload is reused, so this is a free retry.  Default 2; set 0 to fail
# on the first orphan instead of auto-requeuing.
# INGESTION_MAX_RETRIES=2

# Orphan-detection window as a multiple of INGESTION_JOB_TIMEOUT: how long a
# 'processing' job can go without a heartbeat before the reaper treats it as a
# dead worker's leftover.  A live parser heartbeats every few seconds, so the
# default 1.5 surfaces wedged jobs quickly with a safe margin.
# INGESTION_ORPHAN_CUTOFF_MULTIPLIER=1.5

# Hard memory limit for the ingestion worker container.  Default 4g.
# Sized so a 2 GB Nessus parse (peaks ~500 MB-1 GB under
# NESSUS_COMMIT_BATCH_SIZE=50) has headroom and a runaway can't OOM
# the host.  Bump to 8g if MAX_FILE_SIZE > 2 GB.
# WORKER_MEM_LIMIT=4g

# Hard memory limit for the backend API container.  Default 2g.
# Uploads stream chunk-by-chunk to disk so the body never sits fully
# in RAM; this caps the long tail (multiple concurrent uploads + the
# UVICORN_WORKERS budget).  Bump if you raise UVICORN_WORKERS.
# BACKEND_MEM_LIMIT=2g

# -----------------------------------------------------------------------------
# File upload + storage (optional)
# -----------------------------------------------------------------------------
# Where uploaded scan files land.  Defaults to ./uploads under the
# backend working directory.  Override if you want a different host
# mount or a faster disk.
# UPLOAD_DIR=./uploads

# Hard cap on a single upload's size (bytes).  Backend default 1 GB;
# nginx (ssl-nginx.conf) caps at 2 GB by default.  Lower of the two
# wins — change both in lockstep.  Examples:
#   1 GB =  1073741824
#   2 GB =  2147483648
#   5 GB =  5368709120
# Above ~2 GB you'll also want to bump WORKER_MEM_LIMIT (see below)
# and consider chunked upload — browser request memory is the next
# bottleneck.
# MAX_FILE_SIZE=2147483648

# Chunk size used during streamed uploads (bytes).  Default 5 MB.
# UPLOAD_CHUNK_SIZE=5242880

# Where unprocessed upload payloads are staged before the worker
# consumes them.  Defaults to ${UPLOAD_DIR}/ingestion_queue.
# INGESTION_STORAGE_DIR=./uploads/ingestion_queue

# -----------------------------------------------------------------------------
# Nessus ingestion tuning (optional)
# -----------------------------------------------------------------------------
# Adjust these if you experience memory issues or slow ingestion with
# large (>500 MB) Nessus files.  Defaults work well for most cases.
#
# NESSUS_COMMIT_BATCH_SIZE=50
# NESSUS_PLUGIN_OUTPUT_MAX_CHARS=32768

# Max raw-command-output bytes kept per agent test-execution result.
# Default 100 KB (102400).  Bumping retains more raw scanner output
# in the audit trail at the cost of DB size.
# TEST_OUTPUT_MAX_BYTES=102400

# Retention window for agent_api_calls (the audit log of every
# inbound /agent/* request).  Default 90 days.  Set to 0 to disable
# the daily purge loop (use this if you manage retention out-of-band
# or want unbounded history).  The loop runs once every 24h in each
# uvicorn worker; concurrent firings are harmless because the DELETE
# is naturally idempotent.
# AGENT_API_CALL_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Report generation worker (optional)
# -----------------------------------------------------------------------------
# Heavy report formats (PDF / JSON / zip bundles) are generated asynchronously
# on a dedicated report-worker container (mirrors the ingestion worker).  These
# tune its memory, throughput, retention, and size caps.
#
# How often the report worker polls for queued report jobs (seconds). Default 5.
# REPORT_WORKER_POLL_INTERVAL=5
#
# Hard memory limit for the report-worker container.  Default 2g.  In-memory
# formats (PDF/JSON/zip) build the whole document in RAM — raise this if you
# raise REPORT_MAX_HOSTS / REPORT_MAX_INMEMORY_HOSTS.
# REPORT_WORKER_MEM_LIMIT=2g
#
# The report worker's own DB connection pool size (separate from the API).
# Default 3 — it runs one job at a time, so it needs little.
# REPORT_WORKER_DB_POOL_SIZE=3
#
# Where generated report artifacts are written before download/cleanup.
# Defaults to ${UPLOAD_DIR}/report_artifacts (same volume/perms as uploads).
# REPORT_STORAGE_DIR=./uploads/report_artifacts
#
# How long a finished report artifact is kept before the worker's cleanup pass
# deletes it (and its job row).  Default 24 hours.
# REPORT_ARTIFACT_TTL_HOURS=24
#
# A report job stuck 'processing' (no heartbeat) longer than this is re-queued
# or failed by the reaper.  Default 900 (15 min) — must exceed worst-case
# render time for a capped report.
# REPORT_JOB_TIMEOUT_SECONDS=900
#
# Max hosts a single report may include.  The streamed HTML and CSV honor this
# (CSV streams the full filtered set regardless); over the cap, output is
# truncated with a banner rather than silently dropped.  Default 50000.
# REPORT_MAX_HOSTS=50000
#
# Lower cap for the *in-memory* formats (PDF, JSON, zip bundles), which hold the
# whole document in worker RAM at once — a per-host dossier is far heavier than
# an inventory row.  Default 2000.
# REPORT_MAX_INMEMORY_HOSTS=2000
#
# Batch size for the streaming CSV inventory cursor (hosts hydrated + serialized
# per chunk, bounding peak memory regardless of total rows).  Default 500.
# REPORT_STREAM_CHUNK=500

# -----------------------------------------------------------------------------
# Ports (optional)
# -----------------------------------------------------------------------------
# Override default ports if they conflict with other services.
#
# FRONTEND_PORT=3000
# HTTPS_PORT=443
# BACKEND_PORT=8000
# FRONTEND_INTERNAL_PORT=3000

# -----------------------------------------------------------------------------
# Advanced (optional)
# -----------------------------------------------------------------------------
# Path to the nginx config mounted into the frontend container.
# NGINX_CONFIG=./ssl-nginx.conf

# Path to the canonical platform_version.json file.  Backend reads this
# to surface both versions at GET / and in startup logs.  Defaults to
# a search of standard candidate locations; set explicitly only if your
# deployment relocates the file.
# PLATFORM_VERSION_FILE=/app/platform_version.json

# APP_VERSION / FRONTEND_VERSION — version strings shown at GET / and in
# the VersionFooter.  Normally you should NOT set these: they are
# auto-managed from platform_version.json and the docker-compose.yml
# defaults.  Setting them here overrides those defaults and can desync
# the displayed version from the deployed code.  Listed for completeness.
# APP_VERSION=2.46.5
# FRONTEND_VERSION=4.9.1

# CACHE_BUST — value passed to Docker build ARG to invalidate cached
# layers when source code changed but the Dockerfile didn't.  The
# deploy script sets this to a timestamp automatically; manual builds
# can override.
# CACHE_BUST=

# SSL_MODE — toggles SSL-enabled mode in legacy startup checks.
# Production deployments leave this true (the deploy script handles it).
# SSL_MODE=false

# Worker liveness-file paths the container healthchecks read.  These are
# container-internal (under /tmp) — change ONLY if you also change the
# matching healthcheck command in docker-compose.yml, or the worker will
# read as unhealthy.  Defaults are fine for every normal deployment.
# WORKER_HEARTBEAT_PATH=/tmp/bluestick_worker_heartbeat
# REPORT_WORKER_HEARTBEAT_PATH=/tmp/bluestick_report_worker_heartbeat
